<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ruoyi.mapper.TaskUserMapper">

    <resultMap type="TaskUser" id="TaskUserResult">
        <id     property="id"         column="id"/>
        <result property="username"     column="username"/>
        <result property="password"   column="password"/>
        <result property="phone"   column="phone"/>
        <result property="create_time"   column="create_time"/>
    </resultMap>

    <!-- 查询列表 -->
    <select id="selectAllUserInfo" parameterType="TaskUser" resultMap="TaskUserResult">
        select id, username, password, phone, create_time
        from task_user
        <where>
            <if test="id != null"> and id = #{id}</if>
        </where>
    </select>

    <!-- 根据ID查询 -->
    <select id="selectOneTaskUser" parameterType="Long" resultMap="TaskUserResult">
        select id, username, password, phone, create_time
        from task_user
        where id = #{id}
    </select>


    <select id="selectOneUserid" parameterType="com.ruoyi.domain.TaskUser" resultType="Integer">
        select id
        from task_user
        where username = #{username} and password = #{password}
    </select>


    <!-- 新增 -->
    <insert id="insertUserInfo" parameterType="TaskUser">
        insert into task_user (username, password, phone, create_time)
        values (#{username}, #{password}, #{phone},#{create_time})
    </insert>

    <!-- 修改 -->
    <update id="updateOneUserInfo" parameterType="TaskUser">
        update task_user
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="create_time != null">create_time = #{create_time}</if>
        </set>
        where id = #{id}
    </update>

    <!-- 删除 -->
    <delete id="deleteUserInfo" parameterType="Long">
        delete from task_user where id = #{id}
    </delete>

</mapper>
